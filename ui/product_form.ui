<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>ProductForm</class>
 <widget class="QWidget" name="ProductForm">
  <layout class="QVBoxLayout" name="main_layout">
   <item><layout class="QHBoxLayout" name="header">
    <item><widget class="QLabel" name="lbl_fio"><property name="text"><string></string></property><property name="alignment"><set>Qt::AlignRight|Qt::AlignTrailing|Qt::AlignVCenter</set></property></widget></item>
   </layout></item>
   <item><layout class="QGridLayout" name="form_grid">
    <item row="0" column="0"><widget class="QLabel" name="lbl_photo_preview"/></item>
    <item row="1" column="0"><widget class="QPushButton" name="btn_load_photo"><property name="text"><string>Загрузить фото</string></property></widget></item>
    <item row="0" column="1" colspan="2"><widget class="QLineEdit" name="line_name"><property name="placeholderText"><string>Наименование</string></property></widget></item>
    <item row="1" column="1"><widget class="QComboBox" name="combo_category"/></item>
    <item row="2" column="0" colspan="3"><widget class="QTextEdit" name="text_description" maximumHeight="60"/></item>
    <item row="3" column="0"><widget class="QComboBox" name="combo_manufacturer"/></item>
    <item row="3" column="1"><widget class="QLineEdit" name="line_supplier"><property name="placeholderText"><string>Поставщик</string></property></widget></item>
    <item row="3" column="2"><widget class="QLineEdit" name="line_unit"><property name="placeholderText"><string>Ед. изм.</string></property></widget></item>
    <item row="4" column="0"><widget class="QDoubleSpinBox" name="spin_price"><property name="suffix"><string> ₽</string></property><property name="decimals"><number>2</number></property></widget></item>
    <item row="4" column="1"><widget class="QSpinBox" name="spin_qty"><property name="suffix"><string> шт.</string></property><property name="minimum"><number>0</number></property></widget></item>
    <item row="4" column="2"><widget class="QSpinBox" name="spin_discount"><property name="suffix"><string> %</string></property><property name="maximum"><number>100</number></property></widget></item>
   </layout></item>
   <item><widget class="QLabel" name="lbl_id"><property name="text"><string>ID: (только чтение)</string></property></widget></item>
   <item><layout class="QHBoxLayout" name="btn_layout">
    <item><widget class="QPushButton" name="btn_save"><property name="text"><string>Сохранить</string></property></widget></item>
    <item><widget class="QPushButton" name="btn_cancel"><property name="text"><string>Отмена</string></property></widget></item>
    <item><widget class="QPushButton" name="btn_delete" objectName="btn_delete"><property name="text"><string>Удалить</string></property></widget></item>
   </layout></item>
  </layout>
 </widget>
